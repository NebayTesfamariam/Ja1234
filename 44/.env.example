# Environment variables used by this project
# This file is documentation only. The app uses getenv() — it does NOT load .env automatically.
# Set these in your server (Apache SetEnv, php-fpm env, systemd, or export before "php -S").
# Optional: use a loader like vlucas/phpdotenv if you want to read from a .env file.

# --- Production detection (config.php) ---
# ENVIRONMENT=production

# --- Database (config_production.php) ---
# DB_HOST=localhost
# DB_USER=your_db_user
# DB_PASS=your_db_password
# DB_NAME=your_db_name

# --- Base URL (config_production.php) ---
# BASE_URL=https://ja1234.com

# --- WireGuard / VPN (api/get_wireguard_config.php, api/generate_wireguard_qr.php) ---
# VPN_SERVER_ENDPOINT=your-vpn-server.com:51820
# VPN_SERVER_PUBLIC_KEY=YOUR_VPN_SERVER_PUBLIC_KEY
# VPN_DNS=10.10.0.1

# --- DNS whitelist server Python script (dns_whitelist_server.py) ---
# HTTP_HOST=ja1234.com

# --- Stripe (config_stripe.php uses define(), not getenv — add env support if you want) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
