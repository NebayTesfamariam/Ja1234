
# Environment variables used by this project
# This file is documentation only. The app uses getenv() — it does NOT load .env automatically.
# Set these in your server (Apache SetEnv, php-fpm env, systemd, or export before "php -S").
# Optional: use a loader like vlucas/phpdotenv if you want to read from a .env file.

# --- Quick local setup (no password set yet?) ---
# 1. Set MySQL root password once:
#      sudo mysql -e "ALTER USER 'root'@'localhost' IDENTIFIED WITH mysql_native_password BY 'localdev'; FLUSH PRIVILEGES;"
# 2. Create database and tables:
#      DB_PASS=localdev php setup_database.php
# 3. Run the app (use same password):
#      DB_PASS=localdev php -S 0.0.0.0:8080
# Or export so you don't type it every time:
#      export DB_PASS=localdev

# --- Database (config.php uses getenv; dev default: root, no pass) ---
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=localdev
# DB_NAME=pornfree

# --- Base URL (config_production.php) ---
# BASE_URL=https://ja1234.com

# --- WireGuard / VPN (downloaded configs — env-only, no config_vpn.php needed) ---
# Set these so every downloaded WireGuard config has the correct server and works after import.
# See WIREGUARD_ENV_SETUP.md for full steps (generate server key on VPN server, then set env here).
# VPN_SERVER_ENDPOINT=vpn.ja1234.com:51820
# VPN_SERVER_PUBLIC_KEY=<paste output of: cat /etc/wireguard/server_public.key>
# VPN_DNS=10.10.0.1

# Optional: sync script and DNS server use this (or DNS_INTERNAL_KEY)
# VPN_SYNC_KEY=<random secret>

# --- DNS whitelist server Python script (dns_whitelist_server.py) ---
# HTTP_HOST=ja1234.com
# DNS_INTERNAL_KEY=<random secret>   # Set same value on PHP server and when starting DNS server so DNS can fetch whitelist
# VPN_SYNC_KEY=<same or another secret>  # Optional: for scripts/sync_wireguard_peers.sh (can use DNS_INTERNAL_KEY)

# --- Stripe (config_stripe.php uses define(), not getenv — add env support if you want) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
